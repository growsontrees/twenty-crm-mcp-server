# Twenty CRM API Configuration
TWENTY_API_KEY=your_api_key_here
TWENTY_BASE_URL=https://api.twenty.com

# For self-hosted instances, change TWENTY_BASE_URL to your domain:
# TWENTY_BASE_URL=https://your-twenty-instance.com

# Optional: fallback ISO 3166-1 alpha-2 country code for non-E.164 phone strings.
# TWENTY_DEFAULT_COUNTRY_CODE=AU

# --- Transport selection (v0.3.0+) -------------------------------------------
# Default is "stdio" — the existing Claude Desktop / Hermes integration.
# Set MCP_TRANSPORT=http to expose a Streamable-HTTP endpoint instead.
# MCP_TRANSPORT=http

# HTTP transport options (only used when MCP_TRANSPORT=http):
# MCP_HTTP_PORT=8000
# MCP_HTTP_PATH=/mcp
# MCP_BEARER_TOKEN=<openssl rand -hex 32>   # if unset, endpoint is unauthenticated